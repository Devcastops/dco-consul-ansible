{% if packer_build == false %}
retry_join = ["{{ query('inventory_hostnames', 'consul_server') | join('","')}}"]
{% else %}
retry_join = ["{{ consul_address }}"]
{% endif %}

addresses {
  grpc  = "127.0.0.1"
}

ports {
  grpc = 8502
  grpc_tls = 8503
}

acl = {
  enabled = true
}

recursors = ["{{ consul_dns_recursors | join('\",\"') }}"]
